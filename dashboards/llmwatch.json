{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "title": "LLMWatch — LLM Observability",
  "uid": "llmwatch",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [

    {
      "id": 1,
      "title": "Total API Calls",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(llm_request_duration_seconds_count)",
          "legendFormat": "Total Calls"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red",    "value": 1000 }
            ]
          }
        }
      }
    },

    {
      "id": 2,
      "title": "Avg Latency (seconds)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(llm_request_duration_seconds_sum) / sum(llm_request_duration_seconds_count)",
          "legendFormat": "Avg Latency"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red",    "value": 7 }
            ]
          }
        }
      }
    },

    {
      "id": 3,
      "title": "Actual Cost Today (USD)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(llm_actual_cost_usd_total)",
          "legendFormat": "Actual Cost"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 5 }
            ]
          }
        }
      }
    },

    {
      "id": 4,
      "title": "Projected Monthly Cost (USD)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(llm_projected_monthly_cost_usd)",
          "legendFormat": "Projected Monthly"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red",    "value": 50 }
            ]
          }
        }
      }
    },

    {
      "id": 5,
      "title": "Latency Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "rate(llm_request_duration_seconds_sum[1m]) / rate(llm_request_duration_seconds_count[1m])",
          "legendFormat": "Avg latency"
        },
        {
          "expr": "histogram_quantile(0.95, rate(llm_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 latency"
        },
        {
          "expr": "histogram_quantile(0.99, rate(llm_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p99 latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      }
    },

    {
      "id": 6,
      "title": "Cost Forecast Over Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(llm_actual_cost_usd_total)",
          "legendFormat": "Actual cost"
        },
        {
          "expr": "sum(llm_projected_hourly_cost_usd)",
          "legendFormat": "Projected hourly"
        },
        {
          "expr": "sum(llm_projected_daily_cost_usd)",
          "legendFormat": "Projected daily"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": { "mode": "palette-classic" }
        }
      }
    },

    {
      "id": 7,
      "title": "Token Usage Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "rate(llm_input_tokens_total[1m])",
          "legendFormat": "Input tokens/min"
        },
        {
          "expr": "rate(llm_output_tokens_total[1m])",
          "legendFormat": "Output tokens/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      }
    },

    {
      "id": 8,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "rate(llm_errors_total[1m])",
          "legendFormat": "Errors/min — {{error_type}}"
        },
        {
          "expr": "rate(llm_retries_total[1m])",
          "legendFormat": "Retries/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      }
    },

    {
      "id": 9,
      "title": "Agent Decisions Distribution",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum by (decision) (llm_orchestrator_decisions_total)",
          "legendFormat": "{{decision}}"
        }
      ],
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right" }
      }
    },

    {
      "id": 10,
      "title": "Agent Disagreement Score",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 20, "w": 8, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(llm_agent_disagreement_score_bucket[5m]))",
          "legendFormat": "{{agent_name}} — p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(llm_agent_disagreement_score_bucket[5m]))",
          "legendFormat": "{{agent_name}} — p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red",    "value": 0.8 }
            ]
          }
        }
      }
    },

    {
      "id": 11,
      "title": "Debate Turns Per Decision",
      "type": "stat",
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(llm_agent_debate_turns_bucket[5m]))",
          "legendFormat": "Avg debate turns"
        },
        {
          "expr": "histogram_quantile(0.99, rate(llm_agent_debate_turns_bucket[5m]))",
          "legendFormat": "p99 debate turns"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red",    "value": 10 }
            ]
          }
        }
      }
    }

  ]
}